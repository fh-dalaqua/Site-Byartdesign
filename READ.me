/byartdesign-cadeiras
│
├── /assets
│   ├── /css
│   │   ├── _variables.css    # Cores/fontes (ex.: --primary-color: #ff6b6b;)
│   │   ├── _global.css       # Estilos gerais (body, header, footer)
│   │   ├── _home.css         # Estilo do banner hero e seções
│   │   ├── _products.css     # Grid de produtos (como no eMart)
│   │   └── _responsive.css   # Media queries
│   │
│   ├── /js
│   │   ├── cart.js           # Dropdown do carrinho (como no eMart)
│   │   ├── filters.js        # Filtros laterais dinâmicos
│   │   └── product-slider.js # Carrossel de produtos (opcional)
│   │
│   └── /images
│       ├── /products         # Imagens das cadeiras (ex.: cadeira-gamer-1.jpg)
│       ├── /banners          # Banners promocionais
│       └── /icons            # Ícones de redes sociais, etc.
│
├── index.html                # Página inicial (com banner hero)
├── products.html             # Catálogo com filtros laterais
├── product-detail.html       # Página de detalhes (galeria de imagens)
└── cart.html                 # Carrinho de compras (dropdown ou página)